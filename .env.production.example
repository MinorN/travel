NODE_ENV=production

# App
NEXTAUTH_URL=https://your-domain.com
NEXTAUTH_SECRET=replace-with-32-byte-random-secret

# PostgreSQL (container internal hostname is postgres)
POSTGRES_DB=travel
POSTGRES_USER=travel
POSTGRES_PASSWORD=replace-with-strong-password
DATABASE_URL=postgresql://travel:replace-with-strong-password@postgres:5432/travel?schema=public

# Tencent COS
COS_SECRET_ID=
COS_SECRET_KEY=
COS_BUCKET=
COS_REGION=
COS_DOMAIN=
COS_SIGN_EXPIRES=3600

# Optional one-time admin bootstrap
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=管理员
